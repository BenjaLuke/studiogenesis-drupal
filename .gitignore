# Sistema operativo
.DS_Store
Thumbs.db
Desktop.ini

# Editores
.vscode/
.idea/
*.swp
*.swo

# Archivos de entorno local
.env
.env.*
!.env.example

# Composer
/vendor/
composer.lock.bak

# Dependencias de Drupal gestionadas por Composer.
# El codigo propio ira en modules/custom y themes/custom, que si se versionan.
/web/core/
/web/libraries/
/web/modules/contrib/
/web/profiles/contrib/
/web/themes/contrib/

# Archivos generados por Drupal
/web/sites/*/files/
/web/sites/*/private/
/web/sites/*/settings.php
/web/sites/*/services.yml
/web/sites/*/settings.local.php
/web/sites/*/services.local.yml
/web/sites/*/phpunit.xml

# Archivos temporales y copias de seguridad de Drupal
*.orig
*.rej
*.bak
*.tmp

# Logs y cache
*.log
.cache/

# Sobrescrituras locales de Docker
docker-compose.override.yml

# Resultados de pruebas y cobertura
/coverage/
/.phpunit.result.cache

# Archivos locales de base de datos
*.sqlite
*.sqlite3

# Exportaciones SQL locales.
# Se incluiran en el ZIP final si procede, pero no se publican en GitHub.
/database/*.sql
