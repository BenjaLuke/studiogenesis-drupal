# Copy this file to .env before starting the Docker environment.

# Project name used by Docker Compose to group containers, networks and volumes.
COMPOSE_PROJECT_NAME=studiogenesis_drupal

# Public ports exposed in the host machine.
# Change them if another local project is already using the same ports.
DRUPAL_PORT=8081
PHPMYADMIN_PORT=8082
MYSQL_PORT=3308

# Database credentials used by Drupal during installation.
MYSQL_DATABASE=studiogenesis_drupal
MYSQL_USER=drupal
MYSQL_PASSWORD=drupal
MYSQL_ROOT_PASSWORD=root
