# Copia este archivo como .env antes de arrancar el entorno Docker.

# Nombre de proyecto que Docker Compose usa para agrupar contenedores, redes y volumenes.
COMPOSE_PROJECT_NAME=studiogenesis_drupal

# Puertos publicos expuestos en la maquina anfitriona.
# Cambialos si otro proyecto local ya esta usando los mismos puertos.
DRUPAL_PORT=8081
PHPMYADMIN_PORT=8082
MYSQL_PORT=3308

# Credenciales de base de datos que usara Drupal durante la instalacion.
MYSQL_DATABASE=studiogenesis_drupal
MYSQL_USER=drupal
MYSQL_PASSWORD=drupal
MYSQL_ROOT_PASSWORD=root
