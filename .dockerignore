# El historial de Git no hace falta dentro del contexto de construccion Docker.
.git
.gitignore
.gitattributes

# Los valores locales de entorno deben quedarse en la maquina anfitriona.
.env
.env.*
!.env.example

# Las dependencias de Composer y Drupal pueden ser grandes y se montan en ejecucion.
vendor/
web/core/
web/libraries/
web/modules/contrib/
web/profiles/contrib/
web/themes/contrib/
web/sites/*/files/
web/sites/*/private/

# Archivos locales del editor y del sistema operativo.
.vscode/
.idea/
.DS_Store
Thumbs.db
Desktop.ini

# Los artefactos de entrega no deben formar parte del contexto de imagen Docker.
database/*.sql
docs/screenshots/
